{
    "name": "syscage/engine",
    "description": "Core foundation framework for the SysCage ecosystem of Laravel packages.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "syscage", "framework", "plugin", "engine"],
    "homepage": "https://github.com/syscage/engine",
    "authors": [
        {
            "name": "SysCage",
            "homepage": "https://github.com/syscage"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0|^13.0",
        "illuminate/console": "^12.0|^13.0",
        "illuminate/filesystem": "^12.0|^13.0",
        "illuminate/events": "^12.0|^13.0",
        "illuminate/contracts": "^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0|^11.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Syscage\\Engine\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Syscage\\Engine\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Syscage\\Engine\\Providers\\EngineServiceProvider"
            ],
            "aliases": {
                "Engine": "Syscage\\Engine\\Facades\\Engine"
            }
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
